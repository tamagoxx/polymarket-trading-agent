# Polymarket Trading Agent Settings
# ===================================

# MiniMax API (required)
MINIMAX_API_KEY=your_api_key_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=abab6.5s-chat

# Telegram Bot (optional — for auto-signal notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Polymarket API endpoints
GAMMA_API=https://gamma-api.polymarket.com
DATA_API=https://data-api.polymarket.com
CLOB_API=https://clob.polymarket.com

# News API (optional — for news-based signal enhancement)
NEWS_API_KEY=your_news_api_key_here

# Trading Settings
MAX_POSITION_SIZE=100
DEFAULT_BET_AMOUNT=10
MIN_EDGE_THRESHOLD=0.05
MAX_DAILY_LOSS=50

# Logging
LOG_LEVEL=INFO

# Auto-scan interval (minutes)
SCAN_INTERVAL_MINUTES=60
