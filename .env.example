# Polymarket Trading Agent Settings
# ===================================

# MiniMax API (compatible dengan OpenAI SDK)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=abab6.5s-chat

# Polymarket API
POLYMARKET_API_URL=https://clob.polymarket.com
POLYMARKET_API_KEY=

# Polygon RPC
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_WS_URL=wss://polygon-rpc.com/ws

# Data Sources
NEWS_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Trading Settings
MAX_POSITION_SIZE=100  # USD
DEFAULT_BET_AMOUNT=10  # USD
MIN_EDGE_THRESHOLD=0.05  # 5% minimal edge untuk action
MAX_DAILY_LOSS=50  # USD

# Logging
LOG_LEVEL=INFO
